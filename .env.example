# ============================================================
# TRIAGE environment — copy to .env and fill in real values.
# .env is gitignored; .env.example is committed.
# ============================================================

# --- Claude (Anthropic) — reasoning brain across all agents ---
ANTHROPIC_API_KEY=

# --- Browserbase — real cloud browser (ReproAgent only) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Band — THREE distinct agent identities. Keep them separate so one
#     agent can never authenticate as another. ---
BAND_PARSER_API_KEY=
BAND_PARSER_AGENT_ID=
BAND_REPRO_API_KEY=
BAND_REPRO_AGENT_ID=
BAND_HYPOTHESIS_API_KEY=
BAND_HYPOTHESIS_AGENT_ID=
# Optional. If empty, the handshake script creates a new room and prints its ID.
BAND_ROOM_ID=

# --- Trace backend selector ---
# "ax" (Arize AX, app.arize.com — the sponsor-judged surface, PRIMARY) or
# "phoenix" (open-source Phoenix, the fallback). Default is "ax".
TRIAGE_TRACE_BACKEND=ax

# --- Arize AX — retry-loop tracing + evaluators (PRIMARY; required when backend=ax) ---
# Create the API key in ARIZE (app.arize.com → Settings → API Keys). An AX key is
# "ak-..."; spans go to otlp.arize.com via arize.otel.register (no Phoenix env vars).
ARIZE_API_KEY=
# Base64 space ID from app.arize.com (looks like "U3BhY2U6...").
ARIZE_SPACE_ID=
# Project name spans/evals land under in AX. Defaults to triage-bug-repro.
ARIZE_PROJECT_NAME=triage-bug-repro

# --- Arize Phoenix — FALLBACK ONLY (required when TRIAGE_TRACE_BACKEND=phoenix) ---
# Create this in PHOENIX CLOUD (app.phoenix.arize.com → Settings → API Keys), NOT
# in Arize (app.arize.com). A Phoenix key is a JWT (eyJ...); an Arize key (ak-...)
# will 401 against the Phoenix collector.
PHOENIX_API_KEY=
# REQUIRED to be space-scoped for Phoenix Cloud (spaces created after 2025-06-24):
# https://app.phoenix.arize.com/s/<your-space-name>  — copy it from Settings.
# The bare host (no /s/<space>) does not route and returns an empty 401.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<your-space-name>

# --- Target under test ---
TRIAGE_APP_URL=
TRIAGE_GITHUB_ISSUE_URL=
# Phase 7.5 outer loop: when truthy (1/true/yes/on), at run start TRIAGE queries
# Phoenix for prior-run history of this issue and posts a learned-context hint
# into the Band room. Default OFF = the proven inner loop, unchanged.
TRIAGE_OUTER_LOOP=
